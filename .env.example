# Medsuite-eT — copy to .env.local for Vite (prefix VITE_ for client)

# === Frontend API ===
# Dev (default): PHP via Vite proxy — leave unset or use:
# VITE_API_BASE=/api/index.php

# Production on Netlify (serverless PostgreSQL):
# VITE_API_URL=/.netlify/functions/api

# Production with external PHP/MySQL host (recommended for full features):
# VITE_API_BASE=https://api.yourpharmacy.com/api/index.php

# Optional PostgreSQL extended API (PIN, biometric):
# VITE_POSTGRES_API=/api/pg-api.php

# Show PIN tab on login (requires auth_pin on API / PostgreSQL)
# VITE_ENABLE_PIN_AUTH=false

# === Netlify Functions (server-side only — set in Netlify UI) ===
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# JWT_SECRET=use-a-long-random-string
# ALLOWED_ORIGIN=https://your-app.netlify.app
