# Medsuite-eT — Environment Configuration
# Copy to .env for local development
# Or add as Netlify environment variables in Site settings

# === FRONTEND ===
# PHP API URL (relative path works if frontend & backend on same domain)
# Local development: /api/index.php (proxied to php -S on port 8090)
# Production options:
#   - Relative: /api/index.php (if backend served from same domain)
#   - Absolute: https://your-backend-domain.com/api/index.php (if separate domain)
VITE_API_URL=/api/index.php

# === BACKEND (For reference - configure in public/api/config.php) ===
# Database Connection
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=medsuite
# DB_USER=medsuite
# DB_PASS=medsuite_pass_123
# JWT_SECRET=your-super-secret-jwt-key-change-in-production
