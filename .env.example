# Medsuite-eT — Environment Configuration
# Copy to .env for local development
# Or add as Netlify environment variables in Site settings

# === FRONTEND ===
# API URL for frontend to call
# Local development: Use local PHP server or Netlify Functions
# Production: Use Netlify Functions (built-in backend)
VITE_API_URL=/.netlify/functions/api

# === BACKEND (Netlify Functions) ===
# PostgreSQL connection string from Neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# Secret key for JWT token signing
JWT_SECRET=change-this-to-random-secret-in-production
